{
  "manifest_version": 2,
  "name": "Video note-taking",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "tabs",
    "<all_urls>",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-inject.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    "page-replacer.js",
    "main-TA3URN73.js",
    "chunk-ZXQGESBO.js",
    "chunk-FK6H3RFT.js",
    "chunk-E6TGZIGP.js",
    "styles-IRV2JRNT.css",
    "assets/bootstrap-icons/bootstrap-icons.css",
    "media/bootstrap-icons-VQNJTM6Q.woff",
    "media/bootstrap-icons-CVBWLLHT.woff2"
  ]
}
